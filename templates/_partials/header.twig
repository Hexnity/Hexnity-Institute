{% set siteConfigs = craft.app.globals.getSetByHandle('siteConfigs') %}
{% set brandLogo = siteConfigs and siteConfigs.siteLogo is defined ? siteConfigs.siteLogo.one() : null %}
{% set brandName = siteConfigs and siteConfigs.siteName is defined and siteConfigs.siteName ? siteConfigs.siteName : 'Hexnity Institute' %}
{% set brandTagline = siteConfigs and siteConfigs.siteTagline is defined and siteConfigs.siteTagline ? siteConfigs.siteTagline : 'Education and Career Growth' %}

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-gray-100" role="banner">
  <div class="max-w-6xl mx-auto px-5 flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2.5 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2" aria-label="{{ brandName }} home">
      {% if brandLogo %}
        <img src="{{ brandLogo.url }}" alt="{{ brandName }} logo" class="w-8 h-8 rounded object-cover" loading="eager" decoding="async" />
      {% else %}
        <div class="w-8 h-8 bg-brand rounded flex items-center justify-center" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="1" y="1" width="6" height="6" fill="white"/>
            <rect x="11" y="1" width="6" height="6" fill="white"/>
            <rect x="1" y="11" width="6" height="6" fill="white"/>
            <rect x="11" y="11" width="6" height="6" fill="white" opacity=".4"/>
          </svg>
        </div>
      {% endif %}
      <span>
        <span class="block font-bold text-sm leading-tight tracking-wide">{{ brandName }}</span>
        <span class="block text-[10px] text-gray-950 leading-tight uppercase tracking-widest">{{ brandTagline }}</span>
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-7 text-sm text-gray-600 font-medium" aria-label="Primary navigation">
      <a href="#about" class="nav-link focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 rounded">About Us</a>
      <a href="#catalog" class="nav-link focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 rounded">Programs</a>
      <a href="#how" class="nav-link focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 rounded">How We Work</a>
      <a href="#reviews" class="nav-link focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 rounded">Testimonials</a>
      <a href="#contact" class="nav-link focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 rounded">Contact</a>
    </nav>

    <button
      id="mobile-menu-button"
      class="md:hidden text-gray-600 p-2 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open navigation menu"
    >
      <span class="sr-only">Toggle navigation</span>
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <nav id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white" aria-label="Mobile navigation">
    <div class="max-w-6xl mx-auto px-5 py-4 flex flex-col gap-2 text-sm text-gray-700 font-medium">
      <a href="#about" class="mobile-nav-link px-1 py-2 rounded hover:text-brand focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2">About Us</a>
      <a href="#catalog" class="mobile-nav-link px-1 py-2 rounded hover:text-brand focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2">Programs</a>
      <a href="#how" class="mobile-nav-link px-1 py-2 rounded hover:text-brand focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2">How We Work</a>
      <a href="#reviews" class="mobile-nav-link px-1 py-2 rounded hover:text-brand focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2">Testimonials</a>
      <a href="#contact" class="mobile-nav-link px-1 py-2 rounded hover:text-brand focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2">Contact</a>
    </div>
  </nav>
</header>
