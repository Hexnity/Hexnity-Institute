{% set siteConfigs = craft.app.globals.getSetByHandle('siteConfigs') %}
{% set footer = craft.app.globals.getSetByHandle('footer') %}
{% set brandLogo = siteConfigs and siteConfigs.siteLogo is defined ? siteConfigs.siteLogo.one() : null %}
{% set brandName = siteConfigs and siteConfigs.siteName is defined and siteConfigs.siteName ? siteConfigs.siteName : 'Hexnity Institute' %}
{% set brandTagline = siteConfigs and siteConfigs.siteTagline is defined and siteConfigs.siteTagline ? siteConfigs.siteTagline : 'Education and Career Growth' %}

<footer id="contact" class="border-t border-gray-100 bg-gray-50" role="contentinfo">
  <div class="max-w-6xl mx-auto px-5 py-12 flex flex-col md:flex-row justify-between gap-8">
    <div class="md:w-1/3">
      <div class="flex items-center gap-2.5 mb-4">
        {% if brandLogo %}
          <img src="{{ brandLogo.url }}" alt="{{ brandName }} logo" class="w-8 h-8 rounded object-cover" loading="lazy" decoding="async" />
        {% else %}
          <div class="w-8 h-8 bg-brand rounded flex items-center justify-center" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <rect x="1" y="1" width="6" height="6" fill="white"/>
              <rect x="11" y="1" width="6" height="6" fill="white"/>
              <rect x="1" y="11" width="6" height="6" fill="white"/>
              <rect x="11" y="11" width="6" height="6" fill="white" opacity=".4"/>
            </svg>
          </div>
        {% endif %}
        <div>
          <div class="font-bold text-sm leading-tight">{{ brandName }}</div>
          <div class="text-[10px] text-gray-400 leading-tight uppercase tracking-widest">{{ brandTagline }}</div>
        </div>
      </div>
      <p class="text-xs text-gray-400 leading-relaxed">
        {{ footer.footerDescription }}
      </p>
    </div>

    <div class="flex gap-12 text-sm" aria-label="Footer links">
      <div>
        <h2 class="font-semibold mb-3 text-sm">{{ footer.navigationTitle }}</h2>
        <ul class="flex flex-col gap-2 text-gray-500 text-xs">
          {% for link in footer.menus.all() %}
            <li><a href="{{ link.menuPathOrUrl }}" class="hover:text-brand transition">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
      <div>
        <h2 class="font-semibold mb-3 text-sm">{{ footer.navigationTitle2 }}</h2>
        <ul class="flex flex-col gap-2 text-gray-500 text-xs">
          {% for link2 in footer.menus2.all() %}
            <li><a href="{{ link2.menuPathOrUrl }}" class="hover:text-brand transition">{{ link2.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
    </div>

    <address class="text-sm not-italic">
      <h2 class="font-semibold mb-3 text-sm">{{ footer.navigationTitle3 }}</h2>
      <ul class="flex flex-col gap-2 text-gray-500 text-xs">
        {% for link3 in footer.menus3.all() %}
          <li><a href="{{ link3.menuPathOrUrl }}" class="hover:text-brand transition">{{ link3.title }}</a></li>
        {% endfor %}
      </ul>
    </address>
  </div>

  <div class="border-t border-gray-100 py-4 text-center text-xs text-gray-400">
    &copy; {{ now|date('Y') }} {{ footer.copyrightText }}.
  </div>
</footer>
