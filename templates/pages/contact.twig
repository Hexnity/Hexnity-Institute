{% extends "index" %}

{% block title %}Contact — Prostranstvo{% endblock %}

{% block content %}
  <section class="max-w-6xl mx-auto px-5 pt-10 pb-12">
    <div class="relative rounded-2xl overflow-hidden bg-gray-800 min-h-85 md:min-h-100 flex items-end">
      <img src="https://picsum.photos/seed/contactcover/1200/540" alt="City skyline"
           class="absolute inset-0 w-full h-full object-cover opacity-55" />
      <div class="relative z-10 p-8 md:p-12 max-w-2xl">
        <h1 class="hero-text text-4xl md:text-5xl font-extrabold text-white leading-tight mb-4">
          Contact Us
        </h1>
        <p class="text-gray-100 text-sm md:text-base leading-relaxed">
          Tell us what you are looking for, and we will prepare suitable options for your business.
        </p>
      </div>
    </div>
  </section>

  <section id="contact" class="max-w-6xl mx-auto px-5 pb-20">
    <div class="grid md:grid-cols-12 gap-8 md:gap-10 items-start">
      <div class="md:col-span-5">
        <h2 class="text-2xl font-bold mb-3">Get in Touch</h2>
        <p class="text-sm text-gray-500 leading-relaxed mb-6">
          Share your goals and preferred property type. We will contact you with matching options and next steps.
        </p>

        <div class="space-y-3 text-sm text-gray-600">
          <p><span class="font-semibold text-gray-900">Office:</span> Business District, City Center</p>
          <p><span class="font-semibold text-gray-900">Phone:</span> +94 00 000 0000</p>
          <p><span class="font-semibold text-gray-900">Email:</span> hello@example.com</p>
          <p><span class="font-semibold text-gray-900">Hours:</span> Mon - Fri, 9:00 - 18:00</p>
        </div>
      </div>

      <div class="md:col-span-7 border border-gray-100 rounded-2xl p-6 md:p-8 bg-white">
        <form class="grid sm:grid-cols-2 gap-4" method="post" action="#" aria-label="Contact form">
          <div class="sm:col-span-1">
            <label for="name" class="block text-xs font-semibold text-gray-700 mb-2">Name</label>
            <input id="name" name="name" type="text" class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/25 focus:border-brand" />
          </div>

          <div class="sm:col-span-1">
            <label for="company" class="block text-xs font-semibold text-gray-700 mb-2">Company</label>
            <input id="company" name="company" type="text" class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/25 focus:border-brand" />
          </div>

          <div class="sm:col-span-1">
            <label for="email" class="block text-xs font-semibold text-gray-700 mb-2">Email</label>
            <input id="email" name="email" type="email" class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/25 focus:border-brand" />
          </div>

          <div class="sm:col-span-1">
            <label for="phone" class="block text-xs font-semibold text-gray-700 mb-2">Phone</label>
            <input id="phone" name="phone" type="tel" class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/25 focus:border-brand" />
          </div>

          <div class="sm:col-span-2">
            <label for="message" class="block text-xs font-semibold text-gray-700 mb-2">Requirements</label>
            <textarea id="message" name="message" rows="5" class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand/25 focus:border-brand"></textarea>
          </div>

          <div class="sm:col-span-2">
            <button type="submit" class="inline-flex items-center justify-center bg-brand text-white text-sm font-semibold px-6 py-3 rounded-lg hover:opacity-90 transition">
              Send Request
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>
{% endblock %}
