{% extends "index" %}
{% set sectionOne = entry.sectionOne %}
{% set sectionTwo = entry.sectionTwo %}
{% set sectionThree = entry.sectionThree %}
{% set sectionFour = entry.sectionFour %}
{% set sectionFive = entry.sectionFive %}
{% set sectionSix = entry.sectionSix %}
{% block content %}
  <section class="max-w-6xl mx-auto px-5 pt-10 pb-16 js-anim-hero">
    <div style="background-color: {{ sectionOne.backgroundColor ?? '#1F2937' }};" class="relative rounded-2xl overflow-hidden min-h-105 md:min-h-120 flex flex-col md:flex-row items-end js-anim-fade-up">
      <div class="relative z-10 p-8 md:p-14 max-w-xl w-full order-2 md:order-1 js-anim-stagger">
        <h1 class="hero-text text-4xl md:text-5xl font-extrabold text-white leading-tight mb-4 js-anim-stagger-item">
          {{ sectionOne.sectionTitle }}
        </h1>
        <p class="text-gray-200 text-sm md:text-base mb-7 leading-relaxed js-anim-stagger-item">
          {{ sectionOne.sectionDescription }}
        </p>
        <a href="{{ sectionOne.sectionCtaButtonUrl }}" class="inline-block bg-white text-gray-900 font-semibold text-sm px-6 py-3 rounded-lg hover:bg-gray-100 transition js-anim-stagger-item">
          {{ sectionOne.sectionCtaButtonText }}
        </a>
      </div>
      <div class="w-full order-1 md:order-2">
        <img src="{{ sectionOne.homePageCoverImage.one().url }}" alt="{{ sectionOne.homePageCoverImage.one().title }}"
           class="w-full h-64 md:h-full object-cover opacity-80" />
      </div>
    </div>
  </section>

  <section id="about" class="max-w-6xl mx-auto px-5 pb-16 js-anim-reveal">
    <div class="flex flex-col md:flex-row gap-10 items-start">
      <div class="md:w-1/3">
        <h2 class="text-2xl font-bold mb-3">{{ sectionTwo.sectionTitle }} </h2>
        <p class="text-gray-500 text-sm leading-relaxed">
          {{ sectionTwo.sectionDescription }}
        </p>
      </div>

      <div class="md:w-2/3 grid grid-cols-2 sm:grid-cols-4 gap-0 border border-gray-100 rounded-2xl overflow-hidden">
        
        {% set analyticsEntries = entry.sectionTwo.analytics.all() %}

        {% for item in analyticsEntries %}
            <div class="p-6 flex flex-col gap-1">
              <span class="text-3xl font-extrabold text-dark">{{ item.prefix }} {{ item.number }} {{ item.suffix }}</span>
              <span class="text-xs text-gray-400 leading-snug">{{ item.title }}</span>
            </div>
        {% endfor %}

      </div>
    </div>
  </section>

  <section class="border-y border-gray-100 py-8 mb-16 js-anim-reveal">
    <div class="max-w-6xl mx-auto px-5">
      <div class="logo-row">
        {% for partner in sectionThree.partners.all() %}
          {% set image = partner.logoImage.one() %}
          {% if image %}
            <div class="logo-card">
              <a href="{{ partner.partnerUrl }}" target="_blank" rel="noopener noreferrer">
                <img src="{{ image.url }}" alt="{{ partner.title }} logo" loading="lazy" decoding="async" />
              </a>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <section id="catalog" class="max-w-6xl mx-auto px-5 pb-20 js-anim-reveal">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8">
      <div>
        <h2 class="text-2xl font-bold mb-1">{{ sectionFour.sectionTitle }}</h2>
        <p class="text-gray-500 text-sm">{{ sectionFour.sectionDescription }}</p>
      </div>
      <div class="flex gap-2" aria-label="Catalog controls">
        <button class="carousel-btn" type="button" onclick="scrollCatalog(-1)" aria-label="Scroll catalog left" aria-controls="catalog-track">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="carousel-btn" type="button" onclick="scrollCatalog(1)" aria-label="Scroll catalog right" aria-controls="catalog-track">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>
    
    <div id="catalog-track" class="flex gap-5 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-4 -mx-1 px-1" style="scrollbar-width:none;">
      {% for courses in sectionFour.coursesOrProgramms.all() %}
        {% set courseImage = courses.image.one() ?? null %}
        <div class="min-w-65 snap-start shrink-0">
          <img 
            src="{{ courseImage ? courseImage.url : 'https://via.placeholder.com/400x300?text=No+Image' }}" 
            alt="{{ courses.title }}" 
            class="card-img mb-4 object-cover" 
          />
          <h3 class="font-semibold text-sm mb-0.5">{{ courses.title }}</h3>
          <p class="text-xs text-gray-400">{{ courses.description ?? 'Explore our pathways' }}</p>
        </div>
      {% endfor %}
    </div>
  </section>


  <section id="how" class="max-w-6xl mx-auto px-5 pb-20 js-anim-reveal">
    <div class="flex flex-col md:flex-row gap-10 items-start">
      <div class="md:w-2/5 relative">
        <img src="{{ sectionFive.image.one().url }}" alt="{{ sectionFive.sectionTitle }}"
             class="w-full rounded-2xl object-cover" style="aspect-ratio:4/5;" />
        <div style="background-color: {{ sectionFive.highlightBgColor }};" class="absolute bottom-6 left-6 text-white rounded-full w-32 h-32 flex flex-col items-center justify-center text-center shadow-lg">
          <span style="color: {{ sectionFive.highlightTextColor }};" class="font-bold text-sm leading-tight">{{ sectionFive.highlightText }}</span>
        </div>
      </div>

      <div class="md:w-3/5">
        <h2 class="text-2xl font-bold mb-2">{{ sectionFive.sectionTitle }}</h2>
        <p class="text-gray-500 text-sm mb-8 leading-relaxed">
          {{ sectionFive.sectionDescription }}
        </p>

        <div class="flex flex-col gap-6 js-anim-stagger">
          
          {% for feature in sectionFive.featuresList.all() %}

            <div class="flex gap-4 items-start js-anim-stagger-item">
              <div class="step-icon bg-blue-50 text-brand">
                <i class="fa-solid fa-{{ feature.listicon.name }}"></i>
              </div>
              <div>
                <h4 class="font-semibold text-sm mb-1">{{ feature.title }}</h4>
                <p class="text-xs text-gray-500 leading-relaxed">{{ feature.description }}</p>
              </div>
            </div>

          {% endfor %} 

        </div>
      </div>
    </div>
  </section>


  <section id="reviews" class="max-w-6xl mx-auto px-5 pb-20 js-anim-reveal" aria-labelledby="reviews-title">
    <div class="flex items-end justify-between gap-4 mb-8">
      <div>
        <h2 id="reviews-title" class="text-2xl font-bold mb-1">{{ sectionSix.sectionTitle }}</h2>
        <p class="text-gray-500 text-sm">{{ sectionSix.sectionDescription }}</p>
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-5 js-anim-stagger">

      {% for gridItems in sectionSix.gridItem.all() %}

      <article class="border border-gray-100 rounded-2xl p-6 bg-white js-anim-stagger-item">
        <h3 class="font-semibold text-sm mb-2">{{ gridItems.title }}</h3>
        <p class="text-sm text-gray-500 leading-relaxed mb-4">{{ gridItems.description }}</p>
        <p class="text-xs font-medium text-gray-700">{{ gridItems.blockFooter }}</p>
      </article>
      
      {% endfor %}

    </div>
  </section>
{% endblock %}

{% block pageScripts %}
  <script src="/dist/home-animations.js" defer></script>
{% endblock %}
