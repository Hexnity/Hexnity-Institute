{% extends "index" %}
{% set sectionOne = entry.sectionOne %}
{% set sectionTwo = entry.sectionTwo %}
{% set sectionThree = entry.sectionThree %}
{% set sectionFour = entry.sectionFour %}
{% set sectionFive = entry.sectionFive %}
{% block content %}
  <section class="max-w-6xl mx-auto px-5 pt-10 pb-16 js-anim-hero">
    <div style="background-color: {{ sectionOne.backgroundColor ?? '#1F2937' }};" class="relative rounded-2xl overflow-hidden min-h-105 md:min-h-120 flex flex-col md:flex-row items-end js-anim-fade-up">
      <div class="relative z-10 p-8 md:p-14 max-w-xl w-full order-2 md:order-1 js-anim-stagger">
        <h1 class="hero-text text-4xl md:text-5xl font-extrabold text-white leading-tight mb-4 js-anim-stagger-item">
          {{ sectionOne.sectionTitle }}
        </h1>
        <p class="text-gray-200 text-sm md:text-base mb-7 leading-relaxed js-anim-stagger-item">
          {{ sectionOne.sectionDescription }}
        </p>
        <a href="{{ sectionOne.sectionCtaButtonUrl }}" class="inline-block bg-white text-gray-900 font-semibold text-sm px-6 py-3 rounded-lg hover:bg-gray-100 transition js-anim-stagger-item">
          {{ sectionOne.sectionCtaButtonText }}
        </a>
      </div>
      <div class="w-full order-1 md:order-2">
        <img src="{{ sectionOne.homePageCoverImage.one().url }}" alt="{{ sectionOne.homePageCoverImage.one().title }}"
           class="w-full h-64 md:h-full object-cover opacity-80" />
      </div>
    </div>
  </section>

  <section id="about" class="max-w-6xl mx-auto px-5 pb-16 js-anim-reveal">
    <div class="flex flex-col md:flex-row gap-10 items-start">
      <div class="md:w-1/3">
        <h2 class="text-2xl font-bold mb-3">{{ sectionTwo.sectionTitle }} </h2>
        <p class="text-gray-500 text-sm leading-relaxed">
          {{ sectionTwo.sectionDescription }}
        </p>
      </div>

      <div class="md:w-2/3 grid grid-cols-2 sm:grid-cols-4 gap-0 border border-gray-100 rounded-2xl overflow-hidden">
        
        {% set analyticsEntries = entry.sectionTwo.analytics.all() %}

        {% for item in analyticsEntries %}
            <div class="p-6 flex flex-col gap-1">
              <span class="text-3xl font-extrabold text-dark">{{ item.prefix }} {{ item.number }} {{ item.suffix }}</span>
              <span class="text-xs text-gray-400 leading-snug">{{ item.title }}</span>
            </div>
        {% endfor %}

      </div>
    </div>
  </section>

  <section class="border-y border-gray-100 py-8 mb-16 js-anim-reveal">
    <div class="max-w-6xl mx-auto px-5">
      <div class="logo-row flex flex-wrap items-center justify-center gap-8 md:gap-14">
        {% for partner in sectionThree.partners.all() %}
          {% set image = partner.logoImage.one() %}
          {% if image %}
            <div class="h-10 flex items-center cursor-pointer justify-center transition-all duration-300">
              <a href="{{ partner.partnerUrl }}" target="_blank" rel="noopener noreferrer">
                <img src="{{ image.url }}" alt="{{ partner.title }} logo" class="h-10 object-contain" loading="lazy" decoding="async" />
              </a>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <section id="catalog" class="max-w-6xl mx-auto px-5 pb-20 js-anim-reveal">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8">
      <div>
        <h2 class="text-2xl font-bold mb-1">{{ sectionFour.sectionTitle }}</h2>
        <p class="text-gray-500 text-sm">{{ sectionFour.sectionDescription }}</p>
      </div>
      <div class="flex gap-2" aria-label="Catalog controls">
        <button class="carousel-btn" type="button" onclick="scrollCatalog(-1)" aria-label="Scroll catalog left" aria-controls="catalog-track">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="carousel-btn" type="button" onclick="scrollCatalog(1)" aria-label="Scroll catalog right" aria-controls="catalog-track">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>
    
    <div id="catalog-track" class="flex gap-5 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-4 -mx-1 px-1" style="scrollbar-width:none;">
      {% for courses in sectionFour.coursesOrProgramms.all() %}
        {% set courseImage = courses.image.one() ?? null %}
        <div class="min-w-65 snap-start shrink-0">
          <img 
            src="{{ courseImage ? courseImage.url : 'https://via.placeholder.com/400x300?text=No+Image' }}" 
            alt="{{ courses.title }}" 
            class="card-img mb-4 object-cover" 
          />
          <h3 class="font-semibold text-sm mb-0.5">{{ courses.title }}</h3>
          <p class="text-xs text-gray-400">{{ courses.description ?? 'Explore our pathways' }}</p>
        </div>
      {% endfor %}
    </div>
  </section>


  <section id="how" class="max-w-6xl mx-auto px-5 pb-20 js-anim-reveal">
    <div class="flex flex-col md:flex-row gap-10 items-start">
      <div class="md:w-2/5 relative">
        <img src="https://picsum.photos/seed/building5/600/700" alt="Building"
             class="w-full rounded-2xl object-cover" style="aspect-ratio:4/5;" />
        <div class="absolute bottom-6 left-6 bg-brand text-white rounded-full w-32 h-32 flex flex-col items-center justify-center text-center shadow-lg">
          <span class="font-bold text-sm leading-tight">Free</span>
          <span class="font-bold text-sm leading-tight">Advising</span>
        </div>
      </div>

      <div class="md:w-3/5">
        <h2 class="text-2xl font-bold mb-2">How We Work</h2>
        <p class="text-gray-500 text-sm mb-8 leading-relaxed">
          We have designed a clear learning journey so each student can progress with confidence.
        </p>

        <div class="flex flex-col gap-6 js-anim-stagger">

          <div class="flex gap-4 items-start js-anim-stagger-item">
            <div class="step-icon bg-blue-50 text-brand">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/></svg>
            </div>
            <div>
              <h4 class="font-semibold text-sm mb-1">Advising and Goal Mapping</h4>
              <p class="text-xs text-gray-500 leading-relaxed">We understand your goals and suggest the right learning path.</p>
            </div>
          </div>

          <div class="flex gap-4 items-start js-anim-stagger-item">
            <div class="step-icon bg-blue-50 text-brand">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
            </div>
            <div>
              <h4 class="font-semibold text-sm mb-1">Program Selection</h4>
              <p class="text-xs text-gray-500 leading-relaxed">Choose from curated programs that match your interests and career plans.</p>
            </div>
          </div>

          <div class="flex gap-4 items-start js-anim-stagger-item">
            <div class="step-icon bg-blue-50 text-brand">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </div>
            <div>
              <h4 class="font-semibold text-sm mb-1">Guided Learning and Mentorship</h4>
              <p class="text-xs text-gray-500 leading-relaxed">Attend interactive sessions with continuous feedback and mentor support.</p>
            </div>
          </div>

          <div class="flex gap-4 items-start js-anim-stagger-item">
            <div class="step-icon bg-blue-50 text-brand">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
            <div>
              <h4 class="font-semibold text-sm mb-1">Assessment and Certification</h4>
              <p class="text-xs text-gray-500 leading-relaxed">We evaluate progress and issue recognized certifications on completion.</p>
            </div>
          </div>

          <div class="flex gap-4 items-start js-anim-stagger-item">
            <div class="step-icon bg-blue-50 text-brand">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <div>
              <h4 class="font-semibold text-sm mb-1">Career and Academic Progression</h4>
              <p class="text-xs text-gray-500 leading-relaxed">Our team supports your next steps toward employment and higher studies.</p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>


  <section id="reviews" class="max-w-6xl mx-auto px-5 pb-20 js-anim-reveal" aria-labelledby="reviews-title">
    <div class="flex items-end justify-between gap-4 mb-8">
      <div>
        <h2 id="reviews-title" class="text-2xl font-bold mb-1">Student Testimonials</h2>
        <p class="text-gray-500 text-sm">What learners say about their journey with us</p>
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-5 js-anim-stagger">
      <article class="border border-gray-100 rounded-2xl p-6 bg-white js-anim-stagger-item">
        <h3 class="font-semibold text-sm mb-2">Data Analytics Diploma</h3>
        <p class="text-sm text-gray-500 leading-relaxed mb-4">The curriculum was practical and well-structured. I built real projects and secured an internship before graduation.</p>
        <p class="text-xs font-medium text-gray-700">Student, School of Computing</p>
      </article>
      <article class="border border-gray-100 rounded-2xl p-6 bg-white js-anim-stagger-item">
        <h3 class="font-semibold text-sm mb-2">Business Management Program</h3>
        <p class="text-sm text-gray-500 leading-relaxed mb-4">Lecturers connected theory with real industry cases. The mentorship helped me move into a leadership role.</p>
        <p class="text-xs font-medium text-gray-700">Alumni, Business School</p>
      </article>
      <article class="border border-gray-100 rounded-2xl p-6 bg-white js-anim-stagger-item">
        <h3 class="font-semibold text-sm mb-2">Career Switch to IT</h3>
        <p class="text-sm text-gray-500 leading-relaxed mb-4">I joined with no tech background. The step-by-step support gave me confidence to start a new career path.</p>
        <p class="text-xs font-medium text-gray-700">Professional Learner</p>
      </article>
    </div>
  </section>
{% endblock %}

{% block pageScripts %}
  <script src="/dist/home-animations.js" defer></script>
{% endblock %}
